<section class="relative h-screen flex flex-col items-center justify-center overflow-hidden bg-base">
  <!-- Background cityscape silhouette — parallax layer (slow) -->
  <div class="absolute inset-0 parallax-layer" data-speed="0.3">
    <svg viewBox="0 0 1440 810" preserveAspectRatio="xMidYMax slice" class="w-full h-full">
      <!-- Noise texture -->
      <filter id="heroNoise"><feTurbulence baseFrequency="0.5" numOctaves="3" seed="2"/><feColorMatrix type="saturate" values="0"/></filter>
      <rect width="1440" height="810" fill="#050505"/>
      <rect width="1440" height="810" filter="url(#heroNoise)" opacity="0.05"/>

      <!-- Distant skyline -->
      <g fill="#0a0a0a" class="skyline-distant">
        <rect x="100" y="450" width="40" height="360"/>
        <rect x="160" y="380" width="60" height="430"/>
        <rect x="240" y="420" width="35" height="390"/>
        <rect x="300" y="350" width="80" height="460"/>
        <rect x="400" y="400" width="50" height="410"/>
        <rect x="470" y="300" width="70" height="510"/>
        <rect x="560" y="360" width="45" height="450"/>
        <rect x="620" y="280" width="90" height="530"/>
        <rect x="730" y="340" width="55" height="470"/>
        <rect x="800" y="250" width="100" height="560"/>
        <rect x="920" y="320" width="60" height="490"/>
        <rect x="1000" y="370" width="75" height="440"/>
        <rect x="1090" y="290" width="85" height="520"/>
        <rect x="1190" y="350" width="50" height="460"/>
        <rect x="1260" y="400" width="70" height="410"/>
        <rect x="1350" y="330" width="90" height="480"/>
      </g>

      <!-- Closer buildings -->
      <g fill="#080808">
        <rect x="0" y="550" width="120" height="260"/>
        <rect x="180" y="500" width="100" height="310"/>
        <rect x="350" y="520" width="130" height="290"/>
        <rect x="550" y="480" width="110" height="330"/>
        <rect x="750" y="530" width="90" height="280"/>
        <rect x="900" y="490" width="140" height="320"/>
        <rect x="1100" y="510" width="100" height="300"/>
        <rect x="1280" y="540" width="160" height="270"/>
      </g>

      <!-- Ground plane -->
      <rect x="0" y="720" width="1440" height="90" fill="#060606"/>
      <line x1="0" y1="720" x2="1440" y2="720" stroke="#111" stroke-width="1"/>

      <!-- Single crimson accent — distant neon sign -->
      <rect x="835" y="270" width="30" height="6" rx="1" fill="#dc2626" opacity="0.8"/>
      <rect x="835" y="270" width="30" height="6" rx="1" fill="#dc2626" opacity="0.15">
        <animate attributeName="opacity" values="0.15;0.3;0.15" dur="4s" repeatCount="indefinite"/>
      </rect>

      <!-- Scattered window lights — flickering -->
      <g fill="#d4a017" opacity="0.12">
        <rect x="320" y="380" width="4" height="5"><animate attributeName="opacity" values="1;0.3;1;0.7;1" dur="6s" repeatCount="indefinite"/></rect>
        <rect x="335" y="400" width="4" height="5"><animate attributeName="opacity" values="0.7;1;0.5;1;0.7" dur="8s" repeatCount="indefinite"/></rect>
        <rect x="485" y="330" width="4" height="5"><animate attributeName="opacity" values="1;0.4;0.8;1;0.6" dur="7s" repeatCount="indefinite"/></rect>
        <rect x="495" y="360" width="4" height="5"/>
        <rect x="640" y="310" width="4" height="5"><animate attributeName="opacity" values="0.8;1;0.3;1;0.8" dur="9s" repeatCount="indefinite"/></rect>
        <rect x="660" y="340" width="4" height="5"/>
        <rect x="820" y="290" width="4" height="5"><animate attributeName="opacity" values="1;0.5;1;0.4;1" dur="5s" repeatCount="indefinite"/></rect>
        <rect x="840" y="310" width="4" height="5"/>
        <rect x="1110" y="320" width="4" height="5"><animate attributeName="opacity" values="0.6;1;0.8;0.4;1" dur="7s" repeatCount="indefinite"/></rect>
        <rect x="1120" y="350" width="4" height="5"/>
      </g>
    </svg>
  </div>

  <!-- Rain layer — parallax (fast, separate from cityscape) -->
  <div class="absolute inset-0 parallax-layer pointer-events-none" data-speed="0.6">
    <svg viewBox="0 0 1440 810" preserveAspectRatio="xMidYMax slice" class="w-full h-full">
      <g stroke="white" stroke-width="0.5" opacity="0.05">
        <line x1="100" y1="-200" x2="70" y2="810"><animate attributeName="y1" values="-200;810" dur="2.5s" repeatCount="indefinite"/><animate attributeName="y2" values="610;1620" dur="2.5s" repeatCount="indefinite"/></line>
        <line x1="250" y1="-100" x2="220" y2="810"><animate attributeName="y1" values="-100;810" dur="2.2s" repeatCount="indefinite"/><animate attributeName="y2" values="710;1620" dur="2.2s" repeatCount="indefinite"/></line>
        <line x1="400" y1="-300" x2="370" y2="810"><animate attributeName="y1" values="-300;810" dur="2.8s" repeatCount="indefinite"/><animate attributeName="y2" values="510;1620" dur="2.8s" repeatCount="indefinite"/></line>
        <line x1="550" y1="-150" x2="520" y2="810"><animate attributeName="y1" values="-150;810" dur="2.4s" repeatCount="indefinite"/><animate attributeName="y2" values="660;1620" dur="2.4s" repeatCount="indefinite"/></line>
        <line x1="700" y1="-250" x2="670" y2="810"><animate attributeName="y1" values="-250;810" dur="2.6s" repeatCount="indefinite"/><animate attributeName="y2" values="560;1620" dur="2.6s" repeatCount="indefinite"/></line>
        <line x1="850" y1="-50" x2="820" y2="810"><animate attributeName="y1" values="-50;810" dur="2.1s" repeatCount="indefinite"/><animate attributeName="y2" values="760;1620" dur="2.1s" repeatCount="indefinite"/></line>
        <line x1="1000" y1="-180" x2="970" y2="810"><animate attributeName="y1" values="-180;810" dur="2.7s" repeatCount="indefinite"/><animate attributeName="y2" values="630;1620" dur="2.7s" repeatCount="indefinite"/></line>
        <line x1="1150" y1="-280" x2="1120" y2="810"><animate attributeName="y1" values="-280;810" dur="2.3s" repeatCount="indefinite"/><animate attributeName="y2" values="530;1620" dur="2.3s" repeatCount="indefinite"/></line>
        <line x1="1300" y1="-120" x2="1270" y2="810"><animate attributeName="y1" values="-120;810" dur="2.9s" repeatCount="indefinite"/><animate attributeName="y2" values="690;1620" dur="2.9s" repeatCount="indefinite"/></line>
        <line x1="175" y1="-220" x2="145" y2="810"><animate attributeName="y1" values="-220;810" dur="2.5s" repeatCount="indefinite"/><animate attributeName="y2" values="590;1620" dur="2.5s" repeatCount="indefinite"/></line>
        <line x1="475" y1="-80" x2="445" y2="810"><animate attributeName="y1" values="-80;810" dur="2.0s" repeatCount="indefinite"/><animate attributeName="y2" values="730;1620" dur="2.0s" repeatCount="indefinite"/></line>
        <line x1="775" y1="-350" x2="745" y2="810"><animate attributeName="y1" values="-350;810" dur="3.0s" repeatCount="indefinite"/><animate attributeName="y2" values="460;1620" dur="3.0s" repeatCount="indefinite"/></line>
        <line x1="1075" y1="-160" x2="1045" y2="810"><animate attributeName="y1" values="-160;810" dur="2.4s" repeatCount="indefinite"/><animate attributeName="y2" values="650;1620" dur="2.4s" repeatCount="indefinite"/></line>
      </g>
    </svg>
  </div>

  <!-- Floating particles -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" id="hero-particles">
    <div class="particle" style="left:10%;animation-delay:0s;"></div>
    <div class="particle" style="left:25%;animation-delay:1.5s;"></div>
    <div class="particle" style="left:40%;animation-delay:3s;"></div>
    <div class="particle" style="left:55%;animation-delay:0.8s;"></div>
    <div class="particle" style="left:70%;animation-delay:2.2s;"></div>
    <div class="particle" style="left:85%;animation-delay:4s;"></div>
    <div class="particle particle--crimson" style="left:50%;animation-delay:2.5s;"></div>
    <div class="particle" style="left:15%;animation-delay:3.5s;"></div>
    <div class="particle" style="left:90%;animation-delay:1s;"></div>
  </div>

  <!-- Crimson scan line -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="scan-line"></div>
  </div>

  <!-- Figure silhouette — parallax layer (medium, separate) -->
  <div class="absolute inset-0 parallax-layer pointer-events-none" data-speed="0.15">
    <svg viewBox="0 0 1440 810" preserveAspectRatio="xMidYMax slice" class="w-full h-full">
      <g transform="translate(720, 440)">
        <circle cx="0" cy="-32" r="10" fill="#060606"/>
        <rect x="-9" y="-22" width="18" height="30" rx="2" fill="#060606"/>
        <polygon points="-9,-5 -18,25 -5,25" fill="#060606"/>
        <polygon points="9,-5 18,25 5,25" fill="#060606"/>
        <rect x="-8" y="8" width="7" height="30" fill="#060606"/>
        <rect x="1" y="8" width="7" height="30" fill="#060606"/>
      </g>
    </svg>
  </div>

  <!-- Title treatment — parallax layer (foreground) -->
  <div class="relative z-10 text-center px-6 parallax-layer" data-speed="-0.1">
    <div class="font-mono text-[10px] text-text-dim tracking-[6px] uppercase mb-6 hero-fade hero-fade--1">PERSISTENT EXTRACTION WARZONE</div>
    <h1 class="font-display text-5xl sm:text-7xl lg:text-8xl font-black uppercase tracking-tight leading-[0.9] hero-fade hero-fade--2">
      CONTRABAND<br>
      <span class="text-crimson">SKIES</span>
    </h1>
    <div class="w-16 h-[3px] bg-crimson mx-auto mt-6 mb-6 hero-fade hero-fade--3 crimson-line-grow"></div>
    <p class="font-display text-lg sm:text-xl text-text-muted italic max-w-md mx-auto hero-fade hero-fade--4">
      Fly fast. Fight grounded. Extract everything.
    </p>
  </div>

  <!-- Scroll indicator with bounce -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 hero-fade hero-fade--5">
    <div class="animate-bounce">
      <div class="w-px h-10 bg-gradient-to-b from-transparent to-text-faint mx-auto mb-2"></div>
      <div class="font-mono text-[8px] text-text-faint tracking-[3px] uppercase">SCROLL</div>
    </div>
  </div>
</section>
